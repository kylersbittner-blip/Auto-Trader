# Alpaca Markets (get free keys at alpaca.markets)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
TRADING_MODE=paper
ALLOW_LIVE_TRADING=false

# Polygon.io (free tier works for delayed data)
POLYGON_API_KEY=your_polygon_key_here

# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql+asyncpg://trader:trader@localhost:5432/autotrader

# Required for POST/PUT endpoints that start the engine, change config, or place trades.
CONTROL_API_KEY=replace_with_a_long_random_value

# Engine defaults (can be overridden via API)
WATCHLIST=NVDA,AAPL,TSLA,META,AMD,MSFT,AMZN,GOOGL
AUTO_EXECUTE=false         # safer default: signals only, no automatic orders
MIN_CONFIDENCE=72          # % threshold to auto-execute
MAX_POSITION_USD=5000      # max $ per position
MAX_DAILY_TRADES=5         # daily execution cap
DAILY_LOSS_LIMIT_USD=2000  # halt engine if day loss exceeds this
STOP_LOSS_PCT=2.0          # % stop loss per trade
TAKE_PROFIT_PCT=4.0        # % take profit per trade
STRATEGY=momentum          # momentum | mean_reversion | breakout | scalping

# Model
SENTIMENT_MODEL=ProsusAI/finbert   # HuggingFace model ID
